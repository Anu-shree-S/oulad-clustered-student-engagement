            BEHAVIOUR_TILE_CONFIG = [
                {
                    "key": "study_consistency", "label": "Study Consistency",
                    "features": ["active_weeks_ratio_norm", "active_weeks_ratio_Q1",
                                 "active_weeks_ratio_Q2", "active_weeks_ratio_Q3", "active_weeks_ratio_Q4"],
