          type: code
          content: >-
            datasets = {
                "studentInfo": studentInfo,
                "studentVle": studentVle,
                "assessments": assessments,
                "studentAssessment": studentAssessment,
                "courses": courses,
                "vle": vle,
                "studentRegistration": studentReg
            }


            for name, df in datasets.items():
                print(f"\n{'='*40}")
                print(f"{name}")
