            #     ent      = -(P * logP).sum(axis=1)

            #     ent_norm = ent / (np.log(weeks_observed) + eps)


            #     new_feat = pd.DataFrame({

            #         f"content_engagement{suffix}":           content_eng,

            #         f"assessment_engagement{suffix}":        assess_eng,

            #         f"social_engagement{suffix}":            social_eng,

