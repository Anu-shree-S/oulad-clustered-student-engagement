            # Intervention catalogue


            import numpy as np

            import pandas as pd

            from scipy.stats import pointbiserialr, f_oneway


            # A1 — Intervention catalogue


            INTERVENTION_CATALOGUE = {

                #  Assessment behaviour 
                "AP_full": {
